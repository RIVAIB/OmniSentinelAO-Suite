# .env.local.example — OmniSentinelAO-Suite
# Copy to .env.local and fill in all values before running the app.

# ── Supabase ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Anthropic (Claude) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Google AI (Gemini) ─────────────────────────────────────────────────────────
GOOGLE_AI_API_KEY=AIza...

# ── OpenAI (Whisper voice transcription + mem0 LLM/embedder) ──────────────────
OPENAI_API_KEY=sk-...

# ── Telegram Bots ─────────────────────────────────────────────────────────────
TELEGRAM_WEBHOOK_SECRET=your-random-secret-here
TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321

TELEGRAM_CLAUD_TOKEN=bot_token_from_botfather
TELEGRAM_GEM_TOKEN=bot_token_from_botfather
TELEGRAM_CLAWDIO_TOKEN=bot_token_from_botfather
TELEGRAM_JESSY_TOKEN=bot_token_from_botfather
TELEGRAM_NEXUS_TOKEN=bot_token_from_botfather
TELEGRAM_APEX_TOKEN=bot_token_from_botfather
TELEGRAM_AXIOM_TOKEN=bot_token_from_botfather
TELEGRAM_FORGE_TOKEN=bot_token_from_botfather

# ── Site URL (used for Telegram webhook registration) ─────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ── GitHub / Vercel (MCP tools — optional) ────────────────────────────────────
GITHUB_TOKEN=ghp_...
VERCEL_TOKEN=...

# ── mem0 Memory Server (docker-compose local) ─────────────────────────────────
MEMU_BASE_URL=http://localhost:8000
